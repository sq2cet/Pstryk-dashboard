# Pstryk Dashboard — environment configuration
#
# Copy this file to `.env` (gitignored) and fill in real values before
# running. Anything marked REQUIRED must be set; the app will refuse to
# start otherwise. Settings entered through the /settings UI are stored
# encrypted in the SQLite DB and override any matching env var.

# REQUIRED — Fernet key used to encrypt API keys at rest in the DB.
# Generate one with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# OPTIONAL — Database file path (relative to the project root).
DATABASE_URL=sqlite:///./data/pstryk.db

# OPTIONAL — Default timezone for display and aggregates.
TZ=Europe/Warsaw

# OPTIONAL — Host/port for uvicorn when running outside Docker.
HOST=127.0.0.1
PORT=8000

# OPTIONAL — Host port published by docker compose (override on SBC if 8765 is taken).
HOST_PORT=8765

# OPTIONAL — Image tag used by docker-compose.yml in production.
TAG=latest
